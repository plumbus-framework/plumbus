{
  "name": "@plumbus/ui",
  "version": "0.1.0",
  "description": "Plumbus UI — client generation and frontend templates",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "instructions"],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run --passWithNoTests",
    "test:browser": "vitest run --config vitest.config.browser.ts --passWithNoTests",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["plumbus", "ui", "frontend"],
  "license": "MIT",
  "dependencies": {
    "plumbus-core": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@vitest/browser": "^3.0.0",
    "playwright": "^1.52.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
